                    // Task fără stup explicit — încearcă să extragă stupul din text
                    // Format tratament: "Apivar (Doza 1/2) - Stup 1"
                    $match = [];
                    if (preg_match('/-\s*(.+)$/', $row['text'] ?? '', $match)) {
