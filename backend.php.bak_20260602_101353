    $fnCanAccessHive = function(string $stupName) use ($currentUser, $isAdmin, $usersData, $metadataFile, $controllersFile, $manualHivesFile): bool {
        if ($isAdmin) return true;
        if (empty($stupName)) return true; // stup gol — permis (task general)
        // Construim lista de chipID-uri permise
        $meta      = json_decode(file_get_contents($metadataFile), true) ?: [];
