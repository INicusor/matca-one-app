                if (isset($ctrlData[$ctrlId]['chipIDs'])) {
                    $userHives = array_unique(array_merge($userHives, $ctrlData[$ctrlId]['chipIDs']));
                }
            }
        }
        $allowed = [];
        foreach ($userHives as $cid) {
            $cid = (string)$cid;
            $allowed[] = strtolower($cid);
            $allowed[] = strtolower($meta[$cid]['nickname'] ?? $cid);
            $allowed[] = strtolower('stup ' . $cid);
        }
        if (!empty($usersData[$currentUser]['can_manage_manual'])) {
            $mh = json_decode(file_get_contents($manualHivesFile), true) ?: [];
            foreach ($mh as $h) {
                $cid = (string)($h['chipID'] ?? '');
                $allowed[] = strtolower($cid);
                if (!empty($meta[$cid]['nickname'])) $allowed[] = strtolower($meta[$cid]['nickname']);
                if (!empty($h['nickname'])) $allowed[] = strtolower($h['nickname']);
            }
        }
        return in_array(strtolower(trim($stupName)), array_unique(array_filter($allowed)));
    };

