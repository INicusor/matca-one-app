/**
 * Generează și stochează un token CSRF în sesiune.
 * Returnează token-ul existent dacă există deja.
 */
function generateCsrfToken(): string {
    if (empty($_SESSION['csrf_token'])) {
        $_SESSION['csrf_token'] = bin2hex(random_bytes(32));
    }
    return $_SESSION['csrf_token'];
}

/**
 * Validează token-ul CSRF trimis prin POST.
 * Oprește execuția cu 403 dacă este invalid.
 */
function validateCsrfToken(): void {
    $token = $_POST['csrf_token'] ?? $_SERVER['HTTP_X_CSRF_TOKEN'] ?? '';
    if (empty($_SESSION['csrf_token']) || !hash_equals($_SESSION['csrf_token'], $token)) {
        http_response_code(403);
        die(json_encode(['error' => 'Token de securitate invalid. Reîncarcă pagina.']));
    }
}

/**
 * Rate limiting simplu bazat pe IP + cheie acțiune.
 * $maxAttempts / $windowSeconds per IP.
 */
function checkRateLimit(string $key, int $maxAttempts = 5, int $windowSeconds = 60): bool {
    global $rateLimitFile;
    $ip   = $_SERVER['REMOTE_ADDR'] ?? 'unknown';
    $data = json_decode(file_get_contents($rateLimitFile), true) ?: [];
    $now  = time();
    $rKey = $key . '_' . md5($ip);

    // Curăță intrările expirate
    if (isset($data[$rKey])) {
        $data[$rKey] = array_filter($data[$rKey], fn($ts) => ($now - $ts) < $windowSeconds);
    }

    $count = count($data[$rKey] ?? []);
    if ($count >= $maxAttempts) {
        file_put_contents($rateLimitFile, json_encode($data));
        return false; // Depășit limita
    }

    $data[$rKey][] = $now;
    file_put_contents($rateLimitFile, json_encode($data));
    return true;
}

/**
 * Sanitizează un string: elimină taguri HTML, whitespace excesiv.
 */
function clean(string $val): string {
    return trim(strip_tags($val));
}

/**
 * Validează că un string are lungime acceptabilă.
 */
function validLength(string $val, int $min = 1, int $max = 255): bool {
    $len = mb_strlen($val);
    return $len >= $min && $len <= $max;
}

/* =========================================
   BACKUP AUTOMAT
   Rotație ultimele 7 versiuni per fișier
   ========================================= */
function autoBackup(string $filePath): void {
    if (!file_exists($filePath)) return;
    $backupDir = __DIR__ . '/backups';
    if (!is_dir($backupDir)) @mkdir($backupDir, 0755, true);
    $baseName  = basename($filePath, '.json');
    $timestamp = date('Ymd_His');
    $backupPath = "{$backupDir}/{$baseName}_{$timestamp}.json";
    @copy($filePath, $backupPath);
    // Păstrăm doar ultimele 7 backup-uri per fișier
    $files = glob("{$backupDir}/{$baseName}_*.json");
    if ($files && count($files) > 7) {
        usort($files, fn($a,$b) => filemtime($a) - filemtime($b));
        $toDelete = array_slice($files, 0, count($files) - 7);
        foreach ($toDelete as $f) @unlink($f);
    }
}


